                        </tbody>
                    </table>
                </div>
                <?php if ($payment_code != 'mollie_payment_link') { ?>
                <h4><?php echo $text_mollie_refund; ?></h4>
                <div id="mollie-refund" class="table-responsive">
                    <table class="table table-bordered">
                        <thead>
