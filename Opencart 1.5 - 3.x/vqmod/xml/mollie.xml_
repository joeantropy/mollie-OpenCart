            $molliePaymentDetails = $this->model_payment_mollie->getMolliePaymentMethod($order_info, $this->data['showRefundButton']);
            $this->data['payment_status'] = $molliePaymentDetails['payment_status'];
            $this->data['paymentMethod'] = $molliePaymentDetails['paymentMethod'];
            $this->data['showRefundButton'] = $molliePaymentDetails['showRefundButton'];

