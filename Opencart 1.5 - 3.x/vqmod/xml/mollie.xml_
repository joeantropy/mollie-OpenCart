                url: 'index.php?route=sale/order/history&token=<?php echo $token; ?>&order_id=<?php echo $order_id; ?>',
                type: 'post',
                dataType: 'html',
                data: 'order_status_id=' + encodeURIComponent(json['order_status_id']) + '&notify=' + encodeURIComponent(json['notify_customer']) + '&override=0&append=1&comment=' + encodeURIComponent(json['comment']),
