        $('.success, .warning').remove();
        if (json['error']) {
            $('.box').before('<div class="warning" style="display: none;">' + json['error'] + '</div>');
            $('.warning').fadeIn('slow');
        }
        
        if (json['success']) {
            // Create Credit Order
            if (json['partial_credit_order']) {
                $.ajax({
